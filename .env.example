# CodeSteward Review — local env template
# Copy to .env and fill in secrets as needed.

# Durable state (when set, API/worker/findings use Postgres instead of .steward-data JSON)
DATABASE_URL=postgres://steward:steward@localhost:5432/codesteward
# DATABASE_POOL_MAX=10

# File fallback (used when DATABASE_URL is unset)
STEW_DATA_DIR=.steward-data
# FINDINGS_STORE_PATH=.steward-data/findings.json
# JOB_QUEUE_PATH=.steward-data/jobs.json

# Graph
GRAPH_MOCK=0
# GRAPH_MOCK=1  # unit tests / offline only — demos must use live graph
# GRAPH_MCP_URL=http://localhost:3000/mcp

# Models
MODEL_PROVIDER=openai-compatible
MODEL_NAME=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
XAI_API_KEY=
# LITELLM_BASE_URL=

# SCM
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=dev-insecure
# SCM_PROVIDER=github

# Runtime
PORT=8081
# STEW_WORKER_POLL_MS=1500
# STEW_WORKER_ID=
# AGENT_MAX_CONCURRENT=8
# STEW_MAX_CONCURRENT=8
# STEW_USE_DEEPAGENTS=1
# STEW_SANDBOX_PROVIDER=null
# NATS_URL=
# REPO_PATH=

# Enterprise GitHub connector (preferred over PAT)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=      # PEM with \n escapes, or use:
GITHUB_APP_PRIVATE_KEY_REF=  # env:NAME | file:/path/to/app.pem
GITHUB_APP_INSTALLATION_ID=
GITHUB_API_URL=https://api.github.com
# GITHUB_TOKEN=  # dev-only break-glass; not for production bots

# ── Auth / IdP (Keycloak OIDC) ──────────────────────────────────────
# STEW_AUTH_STRICT=1          # reject open mode (required for production)
# STEW_SECRETS_KEY=           # 64 hex chars or base64 32-byte AES key
# OIDC_ISSUER=http://localhost:8083/realms/codesteward
# OIDC_CLIENT_ID=codesteward-ui
# OIDC_CLIENT_SECRET=         # confidential clients only
# OIDC_REDIRECT_URI=http://localhost:8081/v1/auth/oidc/callback
# OIDC_SCOPES=openid profile email
# STEW_PUBLIC_URL=http://localhost:8080
# Browser-facing API URL (GitHub App manifest redirect / setup). Localhost is OK for create redirect.
# STEW_API_PUBLIC_URL=http://localhost:8081
# Public HTTPS base for GitHub → API webhooks (required for live PR hooks). No localhost.
# Examples: https://api.your-domain.com  |  https://xxxx.ngrok-free.app  |  https://smee.io/<id> (if you terminate there)
# STEW_WEBHOOK_PUBLIC_URL=
# GITHUB_APP_NAME=Codesteward
# STEW_API_KEY_ORGS=local     # or * for multi-org API key (dev only)
# STEW_APPLY_SCM_ENV=1        # single-tenant: mirror App creds into process.env

# GitHub App install (happy path — not PAT)
# GITHUB_APP_SLUG=your-app-slug
# GITHUB_APP_INSTALL_URL=     # optional override
# Setup URL in GitHub App settings: {API}/v1/scm/github/setup

# License (NOT STEW_API_KEY — that is auth only)
# STEW_LICENSE_TIER=oss|pro|enterprise
# STEW_LICENSE_KEY=   # optional; prefer Settings → Upload license
# STEW_LICENSE_FILE=.steward-data/license.key
# STEW_LICENSE_HMAC=  # when set, only signed body.sig keys accepted
# STEW_LICENSE_ENFORCE=1
