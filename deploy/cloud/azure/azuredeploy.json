{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "12002922595688248362"
    }
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "defaultValue": "codesteward",
      "metadata": {
        "description": "Base name for resources"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_D2s_v5",
      "metadata": {
        "description": "VM size (8 GB+ recommended)"
      }
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": {
        "description": "Admin username for SSH"
      }
    },
    "adminPublicKey": {
      "type": "securestring",
      "metadata": {
        "description": "SSH public key"
      }
    },
    "domain": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional public DNS name for TLS (A record → public IP)"
      }
    },
    "acmeEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Let's Encrypt email when domain is set"
      }
    },
    "imageTag": {
      "type": "string",
      "defaultValue": "1.3.0",
      "metadata": {
        "description": "Container image tag"
      }
    },
    "gitRef": {
      "type": "string",
      "defaultValue": "main",
      "metadata": {
        "description": "Git ref to clone"
      }
    }
  },
  "variables": {
    "vmName": "[format('{0}-vm', parameters('namePrefix'))]",
    "nicName": "[format('{0}-nic', parameters('namePrefix'))]",
    "pipName": "[format('{0}-pip', parameters('namePrefix'))]",
    "nsgName": "[format('{0}-nsg', parameters('namePrefix'))]",
    "vnetName": "[format('{0}-vnet', parameters('namePrefix'))]",
    "cloudInit": "[format('#cloud-config\npackage_update: true\npackages:\n  - git\n  - curl\n  - ca-certificates\n  - openssl\n  - python3\n  - jq\n  - gnupg\nwrite_files:\n  - path: /etc/codesteward/boot.env\n    permissions: ''0600''\n    content: |\n      DOMAIN={0}\n      ACME_EMAIL={1}\n      IMAGE_TAG={2}\n      GIT_REF={3}\nruncmd:\n  - |\n    set -euo pipefail\n    exec >>/var/log/codesteward-user-data.log 2>&1\n    echo \"codesteward cloud-init start\"\n    set -a\n    . /etc/codesteward/boot.env\n    set +a\n    export DOMAIN ACME_EMAIL IMAGE_TAG\n    export PUBLIC_IP=\"$(curl -fsS --max-time 3 -H Metadata:true --noproxy ''*'' \\\n      ''http://169.254.169.254/metadata/instance/network/interface/0/ipv4/ipAddress/0/publicIpAddress?api-version=2021-12-13&format=text'' || true)\"\n    REF=\"${{GIT_REF:-main}}\"\n    INSTALL_DIR=/opt/codesteward\n    if [[ ! -d \"$INSTALL_DIR/.git\" ]]; then\n      git clone --depth 1 --branch \"$REF\" https://github.com/Codesteward/codesteward.git \"$INSTALL_DIR\" \\\n        || git clone --depth 1 https://github.com/Codesteward/codesteward.git \"$INSTALL_DIR\"\n    fi\n    cd \"$INSTALL_DIR\"\n    git fetch --depth 1 origin \"$REF\" || true\n    git checkout \"$REF\" 2>/dev/null || true\n    bash \"$INSTALL_DIR/deploy/cloud/first-boot.sh\"\n    echo \"codesteward cloud-init done\"\n', parameters('domain'), parameters('acmeEmail'), parameters('imageTag'), parameters('gitRef'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('nsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "SSH",
            "properties": {
              "priority": 1000,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "22"
            }
          },
          {
            "name": "HTTP",
            "properties": {
              "priority": 1010,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "80"
            }
          },
          {
            "name": "HTTPS",
            "properties": {
              "priority": 1020,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourceAddressPrefix": "*",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "443"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[variables('vnetName')]",
      "location": "[parameters('location')]",
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.60.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "10.60.1.0/24",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
      ]
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[variables('pipName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('nicName')]",
      "location": "[parameters('location')]",
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[reference(resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')), '2023-09-01').subnets[0].id]"
              },
              "privateIPAllocationMethod": "Dynamic",
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]"
              }
            }
          }
        ],
        "networkSecurityGroup": {
          "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('nsgName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('pipName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
      ]
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmName')]",
      "location": "[parameters('location')]",
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('vmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": true,
            "ssh": {
              "publicKeys": [
                {
                  "path": "[format('/home/{0}/.ssh/authorized_keys', parameters('adminUsername'))]",
                  "keyData": "[parameters('adminPublicKey')]"
                }
              ]
            }
          },
          "customData": "[base64(variables('cloudInit'))]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "0001-com-ubuntu-server-jammy",
            "sku": "22_04-lts-gen2",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            },
            "diskSizeGB": 40
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('nicName'))]"
      ]
    }
  ],
  "outputs": {
    "publicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2023-09-01').ipAddress]"
    },
    "uiUrl": {
      "type": "string",
      "value": "[format('http://{0}/', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2023-09-01').ipAddress)]"
    },
    "credentialsPath": {
      "type": "string",
      "value": "/var/lib/codesteward/credentials.txt"
    },
    "sshHint": {
      "type": "string",
      "value": "[format('ssh {0}@{1}', parameters('adminUsername'), reference(resourceId('Microsoft.Network/publicIPAddresses', variables('pipName')), '2023-09-01').ipAddress)]"
    }
  }
}