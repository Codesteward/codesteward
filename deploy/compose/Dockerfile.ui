FROM node:22-bookworm-slim@sha256:6c74791e557ce11fc957704f6d4fe134a7bc8d6f5ca4403205b2966bd488f6b3 AS build
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-workspace.yaml tsconfig.base.json pnpm-lock.yaml ./
COPY packages/ui ./packages/ui
WORKDIR /app/packages/ui

# Browser-visible OIDC (Keycloak) — baked into Vite build
ARG VITE_OIDC_ISSUER=http://localhost:8083/realms/codesteward
ARG VITE_OIDC_CLIENT_ID=codesteward-ui
ARG VITE_OIDC_REDIRECT_URI=http://localhost:8080/auth/callback
ARG VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8080/
ARG VITE_OIDC_SCOPES="openid profile email"
ARG VITE_API_URL=
ENV VITE_OIDC_ISSUER=$VITE_OIDC_ISSUER \
    VITE_OIDC_CLIENT_ID=$VITE_OIDC_CLIENT_ID \
    VITE_OIDC_REDIRECT_URI=$VITE_OIDC_REDIRECT_URI \
    VITE_OIDC_POST_LOGOUT_REDIRECT_URI=$VITE_OIDC_POST_LOGOUT_REDIRECT_URI \
    VITE_OIDC_SCOPES=$VITE_OIDC_SCOPES \
    VITE_API_URL=$VITE_API_URL

RUN pnpm install --frozen-lockfile=false
RUN pnpm run build

FROM nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
COPY --from=build /app/packages/ui/dist /usr/share/nginx/html
COPY deploy/compose/nginx-ui.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
