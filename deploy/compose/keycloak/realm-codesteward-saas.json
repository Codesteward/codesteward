      ],
      "groups": [
        "/orgs/local"
      ]
    },
    {
      "username": "service-account-codesteward-api",
      "enabled": true,
      "serviceAccountClientId": "codesteward-api",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "manage-clients",
          "view-clients",
          "query-groups",
          "manage-realm",
          "view-realm",
          "query-realms"
        ]
      }
    },
    {
      "username": "owner@acme.test",
      "email": "owner@acme.test",
