      ]
    },
    {
      "username": "owner@proco.test",
      "email": "owner@proco.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Pro",
      "lastName": "Co",
      "credentials": [
        {
          "type": "password",
          "value": "demo-change-me",
          "temporary": false
        }
      ],
      "realmRoles": [
        "steward-admin"
      ],
      "groups": [
        "/orgs/proco"
      ]
    },
    {
      "username": "owner@entco.test",
      "email": "owner@entco.test",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Ent",
      "lastName": "Co",
      "credentials": [
        {
          "type": "password",
          "value": "demo-change-me",
          "temporary": false
        }
      ],
      "realmRoles": [
        "steward-admin"
      ],
      "groups": [
        "/orgs/entco"
      ]
    }
  ]
}
