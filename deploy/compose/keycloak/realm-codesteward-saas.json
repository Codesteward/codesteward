{
  "realm": "codesteward",
  "enabled": true,
  "displayName": "Codesteward Cloud (SaaS demo)",
  "displayNameHtml": "<strong>Codesteward Cloud</strong>",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "sslRequired": "external",
  "loginTheme": "codesteward",
  "accountTheme": "keycloak.v2",
  "emailTheme": "keycloak",
  "internationalizationEnabled": false,
  "roles": {
    "realm": [
      {
        "name": "steward-admin",
        "description": "Codesteward org admin"
      },
      {
        "name": "steward-reviewer",
        "description": "Codesteward reviewer"
      },
      {
        "name": "steward-viewer",
        "description": "Codesteward viewer"
      }
    ]
  },
  "groups": [
    {
      "name": "orgs",
      "path": "/orgs",
      "subGroups": [
        {
          "name": "local",
          "path": "/orgs/local",
          "attributes": {
            "displayName": [
              "Local"
            ],
            "codesteward_org": [
              "local"
            ]
          }
        },
        {
          "name": "acme",
          "path": "/orgs/acme",
          "attributes": {
            "displayName": [
              "Acme (free)"
            ],
            "codesteward_org": [
              "acme"
            ]
          }
        },
        {
          "name": "proco",
          "path": "/orgs/proco",
          "attributes": {
            "displayName": [
              "ProCo (pro)"
            ],
            "codesteward_org": [
              "proco"
            ]
          }
        },
        {
          "name": "entco",
          "path": "/orgs/entco",
          "attributes": {
            "displayName": [
              "EntCo (enterprise)"
            ],
            "codesteward_org": [
              "entco"
            ]
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "codesteward-ui",
      "name": "Codesteward UI",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:9080/*",
        "http://localhost:9080/auth/callback",
        "http://127.0.0.1:9080/*",
        "http://127.0.0.1:9080/auth/callback",
        "http://localhost:9081/*",
        "http://127.0.0.1:9081/*",
        "http://localhost:9095/*",
        "http://localhost:9095/portal",
        "http://localhost:9095/portal/*",
        "http://127.0.0.1:9095/*"
      ],
      "webOrigins": [
        "http://localhost:9080",
        "http://127.0.0.1:9080",
        "http://localhost:9081",
        "http://127.0.0.1:9081",
        "+",
        "http://localhost:9095",
        "http://127.0.0.1:9095"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:9080/*##http://127.0.0.1:9080/*##+##http://localhost:9095/*##http://127.0.0.1:9095/*"
      },
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "foo",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "codesteward-api",
      "name": "Codesteward API (Admin service account)",
      "enabled": true,
      "publicClient": false,
      "secret": "steward-api-dev-secret-change-me",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "admin@codesteward.local",
      "email": "admin@codesteward.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Steward",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin-change-me",
          "temporary": false
        }
      ],
