OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
SPACEXAI_API_KEY=
# Alias (legacy): XAI_API_KEY=
LITELLM_BASE_URL=
