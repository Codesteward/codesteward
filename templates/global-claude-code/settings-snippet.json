{
  "mcpServers": {
    "codesteward-graph": {
      "command": "uvx",
      "args": [
        "--from",
        "codesteward-mcp[graph-all,graphqlite]",
        "codesteward-mcp",
        "--transport",
        "stdio"
      ],
      "env": {
        "GRAPH_BACKEND": "graphqlite"
      }
    }
  }
}
