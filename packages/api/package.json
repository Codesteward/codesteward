{
  "name": "@codesteward/api",
  "version": "1.4.0",
  "description": "CodeSteward Review HTTP API (Hono)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "stew-api": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch --import tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'no tests'",
    "lint": "echo 'lint:ok'"
  },
  "dependencies": {
    "@codesteward/agents": "workspace:*",
    "@codesteward/core": "workspace:*",
    "@codesteward/db": "workspace:*",
    "@codesteward/findings": "workspace:*",
    "@codesteward/graph-client": "workspace:*",
    "@codesteward/learning": "workspace:*",
    "@codesteward/model-router": "workspace:*",
    "@codesteward/policy": "workspace:*",
    "@codesteward/sandbox": "workspace:*",
    "@codesteward/scm": "workspace:*",
    "@codesteward/webhooks": "workspace:*",
    "@hono/node-server": "^1.14.1",
    "hono": "^4.7.5",
    "jose": "^5.9.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist"
  ],
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "nats": "^2.29.3",
    "amqplib": "^0.10.5",
    "pulsar-client": "^1.12.0"
  }
}
