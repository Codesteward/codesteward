# Codesteward MCP Graph Server
# Multi-stage build — keeps the final image lean.
#
# Build targets:
#   default (graph-all)  — all 14 tree-sitter language grammars
#   graph-core           — TypeScript / JavaScript / Python / Java only
#   base                 — no tree-sitter (Neo4j query-only mode)
#
# Taint analysis (optional):
#   Pass --build-arg TAINT_VERSION=<version> to bundle the codesteward-taint
#   binary. Omitting it leaves the binary absent; the MCP server starts
#   normally with the four core tools only.
#
# Usage:
#   docker build -t codesteward-mcp .
#   docker build --build-arg TAINT_VERSION=0.1.0 -t codesteward-mcp:taint .
#   docker run -p 3000:3000 \
#     -e NEO4J_URI=bolt://neo4j:7687 \
#     -e NEO4J_USER=neo4j \
#     -e NEO4J_PASSWORD=secret \
#     codesteward-mcp

ARG PYTHON_VERSION=3.12
ARG INSTALL_EXTRA=graph-all
ARG TAINT_VERSION=

# ── taint-fetcher stage ───────────────────────────────────────────────────────
# Downloads the codesteward-taint binary when TAINT_VERSION is set.
# Produces a zero-byte sentinel when not set; the final stage removes it.
FROM alpine:3.20 AS taint-fetcher

ARG TAINT_VERSION

RUN apk add --no-cache curl \
 && mkdir -p /opt/taint \
 && if [ -n "${TAINT_VERSION}" ]; then \
      ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') \
   && curl -fsSL \
        "https://github.com/bitkaio/codesteward-taint/releases/download/v${TAINT_VERSION}/codesteward-taint-linux-${ARCH}" \
        -o /opt/taint/codesteward-taint \
   && chmod +x /opt/taint/codesteward-taint; \
    else \
      touch /opt/taint/codesteward-taint; \
    fi

# ── builder stage ────────────────────────────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim AS builder

ARG INSTALL_EXTRA

WORKDIR /build

# System build deps for tree-sitter native extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy workspace and package sources
COPY pyproject.toml .
COPY packages/ packages/

# Install the MCP package (and its codesteward-graph dependency) into a prefix
# we can copy across.  Both packages are workspace members, so pip resolves them
# from the local packages/ tree without hitting PyPI.
RUN pip install --no-cache-dir --prefix=/install \
    "./packages/codesteward-graph[${INSTALL_EXTRA}]" \
    "./packages/codesteward-mcp"

# ── final stage ──────────────────────────────────────────────────────────────
FROM python:${PYTHON_VERSION}-slim

LABEL org.opencontainers.image.title="Codesteward MCP Graph Server"
LABEL org.opencontainers.image.description="Structural codebase graph server over MCP (HTTP+SSE / stdio)"
LABEL org.opencontainers.image.source="https://github.com/bitkaio/codesteward-mcp"

# Copy installed packages from builder
COPY --from=builder /install /usr/local

# Non-root user for security
RUN useradd --uid 1001 --no-create-home --shell /bin/false codesteward

# Install taint binary — present only when TAINT_VERSION was supplied at build time.
# The taint-fetcher stage always produces a file (zero-byte when not set); we remove
# it here if it is empty so shutil.which() in the MCP server returns None cleanly.
COPY --from=taint-fetcher /opt/taint/codesteward-taint /usr/local/bin/codesteward-taint
RUN if [ ! -s /usr/local/bin/codesteward-taint ]; then \
      rm /usr/local/bin/codesteward-taint; \
    fi

# Workspace directory for build metadata (must be created as root, then chowned)
RUN mkdir -p /workspace && chown codesteward /workspace
VOLUME ["/workspace"]

USER codesteward

ENV TRANSPORT=sse
ENV HOST=0.0.0.0
ENV PORT=3000
ENV WORKSPACE_BASE=/workspace
ENV LOG_LEVEL=INFO

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import socket; s=socket.socket(); s.settimeout(3); s.connect(('localhost',3000)); s.close()" \
    || exit 1

ENTRYPOINT ["codesteward-mcp"]
CMD ["--transport", "sse"]
